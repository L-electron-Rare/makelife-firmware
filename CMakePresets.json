{
    "version": 6,
    "configurePresets": [
        {
            "name": "native",
            "displayName": "Native (Host tests)",
            "generator": "Ninja",
            "binaryDir": "build/native",
            "cacheVariables": {
                "TARGET_ARCH": "native",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "esp32",
            "displayName": "ESP32 (ESP-IDF)",
            "generator": "Ninja",
            "binaryDir": "build/esp32",
            "cacheVariables": {
                "TARGET_ARCH": "esp32",
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "x86",
            "displayName": "x86_64 Linux",
            "generator": "Ninja",
            "binaryDir": "build/x86",
            "cacheVariables": {
                "TARGET_ARCH": "x86",
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "stm32",
            "displayName": "STM32F446RE (Nucleo, arm-none-eabi)",
            "generator": "Ninja",
            "binaryDir": "build/stm32",
            "toolchainFile": "cmake/toolchain-arm-none-eabi.cmake",
            "cacheVariables": {
                "TARGET_ARCH": "stm32",
                "CMAKE_BUILD_TYPE": "Release",
                "BOARD_CONFIG": "${sourceDir}/boards/nucleo-f446re.cmake"
            }
        },
        {
            "name": "rp2040",
            "displayName": "RP2040 (Raspberry Pi Pico, arm-none-eabi)",
            "generator": "Ninja",
            "binaryDir": "build/rp2040",
            "toolchainFile": "cmake/toolchain-arm-none-eabi.cmake",
            "cacheVariables": {
                "TARGET_ARCH": "rp2040",
                "CMAKE_BUILD_TYPE": "Release",
                "BOARD_CONFIG": "${sourceDir}/boards/pico.cmake"
            }
        }
    ]
}
